{
  "mcpServers": {
    "_comment": "Copy entries to ~/.cursor/mcp.json — never commit secrets",
    "mobus": {
      "_comment": "Dataset search across 20+ platforms — https://github.com/mobus-ai/Mobus",
      "url": "https://mcp.mobus.ai/mcp"
    },
    "mobus-local": {
      "_comment": "Optional self-host; clone Mobus, npm install && npm run build, then use dist/main.js",
      "command": "node",
      "args": ["/absolute/path/to/Mobus/dist/main.js"],
      "env": {
        "HF_TOKEN": "",
        "KAGGLE_USERNAME": "",
        "KAGGLE_KEY": "",
        "GOOGLE_API_KEY": "",
        "GOOGLE_CSE_ID": ""
      }
    }
  }
}
