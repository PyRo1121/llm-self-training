{
  "mcpServers": {
    "_comment": "Copy entries to ~/.cursor/mcp.json — never commit secrets",
    "mobus": {
      "_comment": "Local Mobus — Kaggle + HF need env; creds in ~/.kaggle/kaggle.json copied into env below",
      "command": "node",
      "args": ["/home/pyro1121/Documents/Mobus/dist/main.js"],
      "env": {
        "HF_TOKEN": "",
        "KAGGLE_USERNAME": "",
        "KAGGLE_KEY": ""
      }
    },
    "mobus-cloud": {
      "_comment": "Hosted fallback — HF only; Kaggle adapter has no user keys",
      "url": "https://mcp.mobus.ai/mcp"
    }
  }
}
