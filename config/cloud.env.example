# Cloud secrets — copy to config/cloud.env (private repo only)
#
#   cp config/cloud.env.example config/cloud.env
#   # edit, then commit config/cloud.env when repo is private
#
# Vast.ai also accepts HF_TOKEN as a template/instance secret on their website.
# GITHUB_TOKEN needs repo read access for private git clone on boot.

# --- Required for Vast one-command launch ---
VAST_API_KEY=
HF_TOKEN=

# Private GitHub clone (fine-grained PAT: Contents read on llm-self-training)
GITHUB_TOKEN=

# --- Optional overrides ---
# CLOUD_GIT_REPO=PyRo1121/llm-self-training
# CLOUD_GIT_REF=main
# RUN=pyro-coder-h100-v1
# PERSONAL_RATIO=0.75
# CLOUD_TRAIN_MAX_STEPS=

# Vast hardware (defaults tuned for mega HF ingest + H100 train)
# VAST_GPU=H100_SXM
# VAST_DISK_GB=600
# VAST_IMAGE=pytorch/pytorch:2.5.1-cuda12.4-cudnn9-devel
# VAST_OFFER_ID=12345678
# VAST_SEARCH_QUERY=gpu_name=H100_SXM num_gpus=1 disk_space>=600 verified=true rentable=true
# VAST_VOLUME=12345:/workspace/data
# LLM_DATA_DIR=/workspace/data

# Jarvis (alternative provider)
# JARVIS_FS_ID=
# HF_DATASET=PyRo1121/pyro-coder-personal-bundle
