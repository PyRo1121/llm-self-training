# =============================================================================
# LLM Self Training — environment template
# =============================================================================
# Copy:  cp .env.example .env
# Cloud: cp .env.example config/cloud.env  (Vast auto-boot; see docs/cloud/README.md)
# Never commit .env or config/cloud.env.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Paths (optional)
# -----------------------------------------------------------------------------

# LLM_SELF_TRAINING_ROOT=/path/to/llm-self-training
# LLM_DATA_DIR=/mnt/data/llm-self-training


# -----------------------------------------------------------------------------
# 2. Hugging Face
# -----------------------------------------------------------------------------

# Gated datasets (SWE-chat), make public-ingest, Mobus HF preview
# HF_TOKEN=hf_...


# -----------------------------------------------------------------------------
# 3. GitHub harvest
# -----------------------------------------------------------------------------

# Fine-grained PAT: public read + Contents read-only
# GITHUB_TOKEN=ghp_...

# GitHub App — dual rate-limit lane (optional)
# GITHUB_APP_CLIENT_ID=Iv1....
# GITHUB_APP_CLIENT_SECRET=....          # OAuth; not required for installation tokens
# GITHUB_APP_PRIVATE_KEY_PATH=config/github-app.pem
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_DOWNLOAD_ONLY=true

# Resolve installation id:
#   uv run --package llm-dataprep github-harvest --resolve-app-installation YOUR_GITHUB_USER


# -----------------------------------------------------------------------------
# 4. Kaggle — Mobus / dataset search
# -----------------------------------------------------------------------------

# Standard location (Kaggle CLI + Python client): ~/.kaggle/kaggle.json
#   { "username": "your-slug", "key": "legacy-api-key" }
# Do NOT commit config/kaggle.json — gitignored if copied into repo by mistake.

# KAGGLE_USERNAME=your-kaggle-slug
# KAGGLE_API_TOKEN=KGAT_...              # New Bearer token (kaggle.com/settings)

# Mobus MCP (~/.cursor/mcp.json): local server needs KAGGLE_USERNAME + KAGGLE_KEY
# in the mobus entry env block (cloud https://mcp.mobus.ai cannot use your keys).


# -----------------------------------------------------------------------------
# 5. Redis — github-harvest cache
# -----------------------------------------------------------------------------

# make redis-up
# REDIS_PASSWORD=your-local-password
# REDIS_PORT=6380
# REDIS_URL=redis://:url-encoded-password@127.0.0.1:6380/0


# -----------------------------------------------------------------------------
# 6. Cloud — Vast.ai / Jarvis
# -----------------------------------------------------------------------------

# VAST_API_KEY=
# GITHUB_TOKEN=                          # also used for private repo clone on boot
# CLOUD_GIT_REPO=PyRo1121/llm-self-training
# CLOUD_GIT_REF=main
# VAST_GPU=H100_SXM
# VAST_DISK_GB=600
# VAST_VOLUME=12345:/workspace/data

# LLM_CONFIG_PROFILE=cloud-h100
# RUN=pyro-coder-h100-v1
# CLOUD_TRAIN_MAX_STEPS=

# JARVIS_FS_ID=
# HF_DATASET=PyRo1121/pyro-coder-personal-bundle

# TURSO_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# 7. Dataprep performance
# -----------------------------------------------------------------------------

# SCAN_WORKERS=12
# CURATE_WORKERS=12
# PERSONAL_SCAN_WORKERS=8
# PRESIDIO_N_PROCESS=8
# PRESIDIO_BATCH_SIZE=384
# PRESIDIO_SESSION_BATCH=512


# -----------------------------------------------------------------------------
# 8. BLAS thread caps
# -----------------------------------------------------------------------------

# OMP_NUM_THREADS=1
# MKL_NUM_THREADS=1
# OPENBLAS_NUM_THREADS=1
# TOKENIZERS_PARALLELISM=false
