# Copy to .env and fill in locally — never commit .env
# cp .env.example .env

# Repo root override (optional)
# LLM_SELF_TRAINING_ROOT=/path/to/llm-self-training

# Relocate entire data/ tree (optional — large NVMe)
# LLM_DATA_DIR=/mnt/data/llm-self-training

# Hugging Face — gated datasets (SWE-chat, etc.)
# HF_TOKEN=hf_...

# Jarvis cloud train (see docs/oss/CLOUD-TRAIN.md)
# LLM_CONFIG_PROFILE=cloud-h100
# HF_DATASET=PyRo1121/pyro-coder-personal-bundle
# JARVIS_FS_ID=
# CLOUD_TRAIN_MAX_STEPS=

# Turso Cloud (optional — warehouse sync)
# TURSO_AUTH_TOKEN=
# WAREHOUSE_DRIVER=turso

# AWS — Stack v2 dedup S3 fetch only (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
