# Copy to .env locally OR config/cloud.env for private-repo Vast auto-boot
# cp config/cloud.env.example config/cloud.env

# Repo root override (optional)
# LLM_SELF_TRAINING_ROOT=/path/to/llm-self-training

# Relocate entire data/ tree (optional — Vast volume mount)
# LLM_DATA_DIR=/workspace/data

# Hugging Face — gated datasets (SWE-chat, etc.)
# HF_TOKEN=hf_...

# GitHub — public code search harvest (make github-harvest)
# Fine-grained PAT: public read / Contents read-only is enough
# GITHUB_TOKEN=ghp_...

# GitHub App — dual rate-limit lane (optional; separate 5000/hr + 9/min search)
# Client ID from app settings (Iv1....) — NOT a token; also need private key PEM
# GITHUB_APP_CLIENT_ID=Iv1....          # from app settings (not a token)
# GITHUB_APP_CLIENT_SECRET=....         # OAuth only — NOT used for harvest installation tokens
# GITHUB_APP_PRIVATE_KEY_PATH=config/github-app.pem   # required for dual lane
# GITHUB_APP_INSTALLATION_ID=12345678

# Local Redis cache for github-harvest (make redis-up)
# REDIS_PASSWORD=your-local-password
# REDIS_PORT=6380
# REDIS_URL=redis://:your-url-encoded-password@127.0.0.1:6380/0

# Vast.ai — see docs/cloud/README.md
# VAST_API_KEY=
# GITHUB_TOKEN=          # also used for private repo clone on boot
# CLOUD_GIT_REPO=PyRo1121/llm-self-training
# CLOUD_GIT_REF=main
# VAST_GPU=H100_SXM
# VAST_DISK_GB=600
# VAST_VOLUME=12345:/workspace/data

# Cloud train profile (auto-set by train-cloud / --cloud)
# LLM_CONFIG_PROFILE=cloud-h100
# RUN=pyro-coder-h100-v1
# CLOUD_TRAIN_MAX_STEPS=

# Jarvis alternative
# JARVIS_FS_ID=
# HF_DATASET=PyRo1121/pyro-coder-personal-bundle

# Turso Cloud (optional)
# TURSO_AUTH_TOKEN=

# Dataprep perf (16c / 32GB — tune to taste; watch RAM with Presidio)
# SCAN_WORKERS=12              # parallel raw files (public step)
# PERSONAL_SCAN_WORKERS=8      # personal scan in prep step 3
# CURATE_WORKERS=12
# PRESIDIO_N_PROCESS=8         # spaCy processes per file (big win on single huge files)
# PRESIDIO_BATCH_SIZE=512      # rows per Presidio batch (default 256)
# PRESIDIO_SESSION_BATCH=512   # curate session batch size
